# Copy this file to .env if you need the CLI fetch command (garmin-dashboard-fetch)
# without an interactive login. The desktop app uses cached tokens instead.
# .env is gitignored — it will never be committed.
#
# TOKEN-FIRST: after one successful login via the app's Account page, Garmin
# tokens are cached in ~/.garminconnect/ and remain valid for ~1 year.
# GARMIN_PASSWORD is NOT needed (and should NOT be stored) once tokens exist.

GARMIN_EMAIL=you@example.com
# GARMIN_PASSWORD=your-garmin-connect-password   # Only needed if tokens are missing/expired
